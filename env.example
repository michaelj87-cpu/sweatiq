# ============================================================
# SweatIQ AI Fitness Coach — Environment Variables
# ============================================================
# Copy this file to .env and fill in your real values
# Never commit .env to git!

# ── Anthropic ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Stripe ────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Price IDs — create these in Stripe Dashboard > Products
STRIPE_PRICE_PRO_MONTHLY=price_xxxxxxxxxxxxx
STRIPE_PRICE_PRO_ANNUAL=price_xxxxxxxxxxxxx
STRIPE_PRICE_ELITE_MONTHLY=price_xxxxxxxxxxxxx
STRIPE_PRICE_ELITE_ANNUAL=price_xxxxxxxxxxxxx

# ── App ───────────────────────────────────────────────────
PORT=3000
FRONTEND_URL=http://localhost:3000
